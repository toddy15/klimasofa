{
    "name": "klimasofa/inserttags",
    "type": "contao-bundle",
    "description": "Replace some insert tags within contao",
    "license": "MIT",
    "authors": [
        {
            "name": "Dr. Tobias Quathamer",
            "email": "info@klimasofa.org"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "contao/core-bundle": "^4.9",
        "symfony/config": "^4.4 || ^5.1",
        "symfony/dependency-injection": "^4.4 || ^5.1",
        "symfony/http-kernel": "^4.4 || ^5.1"
    },
    "conflict": {
        "contao/manager-plugin": "<2.0 || >=3.0"
    },
    "require-dev": {
        "contao/manager-plugin": "^2.0",
        "phpunit/phpunit": "^9.5",
        "symfony/phpunit-bridge": "^4.4 || ^5.1"
    },
    "extra": {
        "contao-manager-plugin": "Klimasofa\\InserttagsBundle\\ContaoManager\\Plugin"
    },
    "autoload": {
        "psr-4": {
            "Klimasofa\\InserttagsBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Klimasofa\\InserttagsBundle\\Tests\\": "tests/"
        }
    }
}
